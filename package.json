{
  "name": "nrlschedulescraper",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "NRL Schedule Scraper - Cloudflare Workers Edge Application",
  "scripts": {
    "dev": "npm run build && wrangler dev",
    "build": "npm run build:frontend && npm run build:worker",
    "build:frontend": "cd client && npm run build && rm -rf ../dist/frontend && mkdir -p ../dist/frontend && cp -r dist/* ../dist/frontend/",
    "build:worker": "esbuild src/worker.ts --bundle --outfile=dist/worker.js --format=esm --platform=browser --target=es2022",
    "start": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "test": "npm run build:worker && vitest run",
    "test:watch": "npm run build:worker && vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "linkedom": "^0.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/node": "^20.10.6",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.0",
    "miniflare": "^3.20240925.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "wrangler": "^4.69.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
